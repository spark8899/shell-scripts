# .env file
# Database Configuration
DATABASE_URL=mysql+aiomysql://user:password@host:port/database_name # Replace with your MySQL connection string
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=changeme # Change this password!

# JWT Configuration
SECRET_KEY=your_very_secret_key_replace_this # Use a strong, random secret key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging Configuration
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=5242880 # 5MB
LOG_BACKUP_COUNT=5

# Zookeeper Configuration
ZOOKEEPER_HOSTS=127.0.0.1:2181 # Comma-separated list of Zookeeper hosts
